# Required — LLM
ANTHROPIC_API_KEY=sk-ant-...

# Required — Web Search
TAVILY_API_KEY=tvly-...

# Required — Slack
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...

# Required — Notion
NOTION_API_KEY=secret_...
NOTION_PARENT_PAGE_ID=...

# Optional — Model overrides (defaults shown)
MODEL_STAGE_1=claude-opus-4-6
MODEL_STAGE_2=claude-opus-4-6
MODEL_STAGE_3=claude-sonnet-4-6
MODEL_STAGE_4=claude-haiku-4-5-20251001
MODEL_STAGE_5=claude-opus-4-6
MODEL_STAGE_6=claude-opus-4-6
MODEL_STAGE_7=claude-opus-4-6
MODEL_STAGE_8=claude-opus-4-6
MODEL_STAGE_9=claude-opus-4-6
MODEL_INTENT_PARSE=claude-haiku-4-5-20251001
MODEL_IMAGE_PARSE=claude-haiku-4-5-20251001

# Optional — Google Drive (link sharing support)
GOOGLE_API_KEY=
GDRIVE_MAX_FILES=25

# Optional — Pipeline tuning
MAX_CONCURRENT_API_CALLS=3
MAX_RETRIES_PER_STAGE=2
RETRY_DELAY_MS=5000
TAVILY_MAX_RESULTS=5
TAVILY_SEARCH_DEPTH=advanced
SESSIONS_DIR=./sessions
LOG_LEVEL=info
